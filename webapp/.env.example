# ─── Perka Webapp — Environment Variables ─────────────────────────────────────
#
# Copy this file to .env and fill in values for your environment.
# All VITE_* variables are embedded at build time and visible in the browser —
# never put secrets here.
#
# For local development the Vite dev server proxies /api/* to localhost:8000
# automatically, so VITE_API_URL is not required unless you point at a remote
# backend or a non-standard port.

# Backend API base URL.
# Default (local dev with Vite proxy): /api/v1
# Remote / production example:        https://api.yourapp.com/api/v1
VITE_API_URL=/api/v1
