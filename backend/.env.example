DATABASE_URL=postgresql://postgres:postgres@localhost:5432/perka_db
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ── AI concierge engine ───────────────────────────────────────────────────────
# Priority: Google ADK (Gemini) → OpenAI → free rule-based fallback.
# With no keys set, the rule-based engine is used (works offline, no cost).

# Preferred — Google ADK / Gemini agent with tool calling.
# Get a free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Legacy fallback — OpenAI concierge with tool calling.
# Get a key at https://platform.openai.com/api-keys (billing required).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
